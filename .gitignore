# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
debug-*.log
/.cursor/debug-*.log

# local env files
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# backups e arquivos antigos
/_old
*.old
*.backup

/lib/generated/prisma

# uploads de documentos (arquivos grandes)
/public/uploads/*
!/public/uploads/.gitkeep
!/public/uploads/obras/
/public/uploads/obras/*
!/public/uploads/obras/.gitkeep

# arquivos de backup (grandes)
*.rar
*.zip
*.7z
