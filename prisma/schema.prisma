// schema.prisma - CORRIGIDO PARA FINTECH

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --------------------------------------------------------
// ENGENHARIA (O Lastro Físico)
// --------------------------------------------------------

model Construtora {
  id                String      @id @default(uuid())
  codigo            String      @unique // CD-001, CD-002, etc
  razaoSocial       String
  cnpj              String      @unique
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  cep               String?
  cidade            String?
  contaBancaria     Json?
  email             String?
  endereco          String?
  estado            String?
  inscricaoEstadual String?
  nomeFantasia      String?
  socios            Json?
  telefone          String?
  obras             Obra[]
  operacoes         Operacao[]
  documentos        Documento[]
  // Cadastros Financeiros
  credores          Credor[]
  contasBancarias   ContaBancaria[]
  configTaxas       ConfiguracaoTaxas?
  itensCustoIndireto ItemCustoIndireto[]
  tiposDocumento    TipoDocumento[]
  usuariosVinculados UsuarioConstrutora[] // Usuários da construtora
  usuariosFiadoresVinculados UsuarioFiadorConstrutora[] // Usuários do fiador com escopo por construtora
  lancamentosSaldoPerformado SaldoPerformadoLancamento[]
}

model Fundo {
  id                String         @id @default(uuid())
  codigo            String         @unique // CS-001, CS-002, etc
  razaoSocial       String
  cnpj              String         @unique
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  cep               String?
  cidade            String?
  contaBancaria     Json?
  email             String?
  endereco          String?
  estado            String?
  inscricaoEstadual String?
  nomeFantasia      String?
  socios            Json?
  telefone          String?
  documentos        Documento[]
  vinculosObras     VinculoFundo[]  // Vínculos com obras
  usuariosVinculados UsuarioFundo[] // Usuários do fundo
}

model Fiador {
  id                  String          @id @default(uuid())
  codigo              String          @unique // AV-001, AV-002, etc
  tipo                String // 'PF' ou 'PJ'
  // Campo único para CPF ou CNPJ (dependendo do tipo)
  cpfCnpj             String          @unique // CPF (11 dígitos) ou CNPJ (14 dígitos) - sempre limpo (sem formatação)
  // Campos para Pessoa Física (usar nome, cpfCnpj já tem CPF)
  nome                String // Nome completo (PF) ou Razão Social (PJ)
  rg                  String? // RG (se PF)
  estadoCivil         String? // Solteiro, Casado, Divorciado, Viúvo (se PF)
  dataNascimento      DateTime? // Data de nascimento (se PF)
  // Campos para Pessoa Jurídica (usar nome como razaoSocial, cpfCnpj já tem CNPJ)
  nomeFantasia        String? // Nome Fantasia (se PJ)
  inscricaoEstadual   String? // IE (se PJ)
  // Campos comuns
  cep                 String?
  cidade              String?
  email               String?
  endereco            String?
  estado              String?
  telefone            String?
  // Configurações
  aprovadorFinanceiro Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  documentos          Documento[]
  bens                Bem[]
  vinculosObras       VinculoFiador[] // Vínculos com obras
}

model Contratante {
  id                String      @id @default(uuid())
  codigo            String      @unique // SC-001, SC-002, etc
  razaoSocial       String
  cnpj              String      @unique
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  cep               String?
  cidade            String?
  contaBancaria     Json?
  email             String?
  endereco          String?
  estado            String?
  inscricaoEstadual String?
  nomeFantasia      String?
  socios            Json?
  telefone          String?
  documentos        Documento[]
  obras             Obra[] // Relação inversa com Obra
}

model FonteRecurso {
  id             String   @id @default(uuid())
  codigo         String   @unique // FR-001, FR-002, etc
  nome           String
  tipo           String // CONVENIO, FINANCIAMENTO, PROPRIO, MISTO
  esfera         String // FEDERAL, ESTADUAL, MUNICIPAL, PRIVADO
  orgao          String? // Para convênios
  instituicao    String? // Para financiamentos
  numeroProcesso String?
  status         String   @default("ATIVO") // ATIVO, EM_ANDAMENTO, CONCLUIDO, CANCELADO
  observacoes    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  obras          Obra[] // Relação inversa com obras
}

model Medicao {
  id             String     @id @default(uuid())
  obraId         String
  numero         Int
  periodoInicio  DateTime
  periodoFim     DateTime
  dataAprovacao  DateTime?
  valorMedido    Decimal    @db.Decimal(18, 2)
  valorAcumulado Decimal    @db.Decimal(18, 2)
  saldoContrato  Decimal    @db.Decimal(18, 2)
  status         String
  obra           Obra       @relation(fields: [obraId], references: [id])
  operacoes      Operacao[]

  @@unique([obraId, numero])
}

model Obra {
  id                    String                 @id @default(uuid())
  codigo                String // CT-001, CT-002, etc (por construtora)
  nome                  String
  construtoraId         String
  contratanteId         String? // Relação com o contratante pagador
  // Localização
  endereco              String?
  cidade                String?
  estado                String?
  latitude              String?
  longitude             String?
  // Vigência do Contrato
  prazoMeses            Int? // Prazo de vigência do contrato em meses
  dataInicio            DateTime? // Data de início da vigência do contrato
  dataFim               DateTime? // Data de fim da vigência do contrato
  // Execução da Obra
  prazoExecucaoMeses    Int? // Prazo de execução da obra em meses
  dataInicioExecucao    DateTime? // Data de início da execução da obra
  dataFimExecucao       DateTime? // Data prevista de conclusão da obra
  // Valores
  valorContrato         Decimal                @db.Decimal(18, 2)
  // Documentação Técnica
  cno                   String? // Cadastro Nacional de Obras
  art                   String? // Anotação de Responsabilidade Técnica
  alvara                String? // Alvará da obra
  // Parâmetros Financeiros
  bdi                   Decimal?               @db.Decimal(5, 2) // BDI em % (ex: 25.00)
  encargos              Decimal?               @db.Decimal(5, 2) // Encargos sociais em % (ex: 118.00)
  indiceReajuste        String?                // Índice padrão: INCC, IPCA, IGPM, INPC
  periodicidadeMedicao  Int?                   // Periodicidade das medições em meses (ex: 1)
  // Recurso Financeiro
  recursoFinanceiro     String? // Campo legado (será removido)
  fonteRecursoId        String? // ID da fonte de recurso (FK)
  // Status
  status                String                 @default("NAO_INICIADA") // NAO_INICIADA, EM_ANDAMENTO, CONCLUIDA, PARALISADA, CANCELADA
  // Timestamps
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  // Relações
  medicoes              Medicao[]
  documentos            Documento[] // Relação com documentos
  aditivos              Aditivo[] // Relação com aditivos
  reajustes             Reajuste[] // Relação com reajustes
  empenhos              Empenho[] // Relação com empenhos
  construtora           Construtora            @relation(fields: [construtoraId], references: [id])
  contratante           Contratante?           @relation(fields: [contratanteId], references: [id])
  fonteRecurso          FonteRecurso?          @relation(fields: [fonteRecursoId], references: [id])
  vinculoFundo          VinculoFundo? // Relação 1:1 com fundo investidor
  vinculosFiadores      VinculoFiador[] // Relação 1:N com fiadores
  versoesOrcamento      VersaoOrcamento[] // Versões do orçamento (planilha contratual)
  versoesCustoOrcado    VersaoCustoOrcado[] // Versões de custos orçados
  versoesCategorizacao  VersaoCategorizacao[] // Versões de categorização
  versoesVisaoGerencial VersaoVisaoGerencial[] // Versões de visão gerencial
  plantasBaixas         PlantaBaixa[] // Plantas baixas da obra (Registros 360º)
  previsoesMedicao      PrevisaoMedicao[] // Previsões de medição
  historicoVersoesMedicao HistoricoVersaoMedicao[] // Histórico de versões de medição
  mapeamentosItemVersao MapeamentoItemVersao[] // Mapeamentos de itens entre versões
  operacoes             Operacao[] // Operações financeiras vinculadas
  lancamentosSaldoPerformado SaldoPerformadoLancamento[]
  usuariosFiadoresVinculados UsuarioFiadorObra[] // Usuários do fiador com escopo por obra
}

// Aditivos Contratuais
model Aditivo {
  id               String      @id @default(uuid())
  obraId           String
  numero           Int // Número sequencial do aditivo (1, 2, 3...)
  tipo             String // 'VALOR' ou 'PRAZO'
  dataAssinatura   DateTime?
  justificativa    String?     @db.Text
  // Campos para Aditivo de Valor
  valorAditivo     Decimal?    @db.Decimal(18, 2) // Valor adicionado (positivo) ou suprimido (negativo)
  valorGlosa       Decimal?    @db.Decimal(18, 2) // Valor de glosas
  // Campos para Aditivo de Prazo
  tipoUnidadePrazo String? // 'DIAS' ou 'MESES'
  prazoVigencia    Int? // Prazo adicional de vigência
  prazoExecucao    Int? // Prazo adicional de execução
  // Documento (campos legados - mantidos para compatibilidade)
  nomeArquivo      String?
  caminhoArquivo   String?
  // Status
  status           String      @default("EM_ELABORACAO") // EM_ELABORACAO, APROVADO, REJEITADO
  // Timestamps
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  // Relações
  obra             Obra        @relation(fields: [obraId], references: [id], onDelete: Cascade)
  documentos       Documento[] // Múltiplos documentos anexados

  @@unique([obraId, numero]) // Garantir que o número seja único por obra
}

// Reajustes Contratuais (Apostilamentos)
model Reajuste {
  id             String      @id @default(uuid())
  obraId         String
  numero         Int // Número sequencial do reajuste (1, 2, 3...)
  dataBase       String // Data base no formato YYYY-MM (ex: "2024-01")
  indice         String // 'INCC', 'IPCA', 'IGPM', 'INPC'
  percentual     Decimal     @db.Decimal(5, 2) // Percentual acumulado (ex: 5.20)
  valorReajuste  Decimal     @db.Decimal(18, 2) // Valor do reajuste
  dataAplicacao  DateTime // Data de aplicação do reajuste
  observacoes    String?     @db.Text
  // Documento (campo legado para compatibilidade)
  nomeArquivo    String?
  caminhoArquivo String?
  // Status
  status         String      @default("PENDENTE") // PENDENTE, APLICADO, CANCELADO
  // Timestamps
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  // Relações
  obra           Obra        @relation(fields: [obraId], references: [id], onDelete: Cascade)
  documentos     Documento[] // Múltiplos documentos (memória de cálculo, etc)

  @@unique([obraId, numero]) // Garantir que o número seja único por obra
}

// Empenhos (Notas de Empenho - Lastro Orçamentário)
model Empenho {
  id             String      @id @default(uuid())
  obraId         String
  numero         Int // Número sequencial do empenho (1, 2, 3...)
  numeroNE       String // Número da Nota de Empenho (ex: NE-2024-001)
  dataEmissao    DateTime // Data de emissão da NE
  valor          Decimal     @db.Decimal(18, 2) // Valor empenhado
  saldoAtual     Decimal     @default(0) @db.Decimal(18, 2) // Saldo disponível (calculado)
  tipo           String // 'ORIGINAL' ou 'REFORCO'
  alertaMinimo   Decimal?    @db.Decimal(18, 2) // Valor mínimo para alerta de saldo
  observacoes    String?     @db.Text
  // Documento (campo legado para compatibilidade)
  nomeArquivo    String?
  caminhoArquivo String?
  // Status
  status         String      @default("ATIVO") // ATIVO, ESGOTADO, CANCELADO
  // Timestamps
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  // Relações
  obra           Obra        @relation(fields: [obraId], references: [id], onDelete: Cascade)
  documentos     Documento[] // Múltiplos documentos anexados

  @@unique([obraId, numero]) // Garantir que o número seja único por obra
}

// Vínculo entre Obra e Fundo (1:1 - apenas 1 fundo por obra)
model VinculoFundo {
  id           String   @id @default(uuid())
  obraId       String   @unique // Cada obra pode ter apenas 1 fundo vinculado
  fundoId      String
  percentual   Decimal  @db.Decimal(5, 2) // Ex: 100.00
  valorAlocado Decimal  @db.Decimal(18, 2)
  observacoes  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  // Relações
  obra         Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)
  fundo        Fundo    @relation(fields: [fundoId], references: [id])
}

// Vínculo entre Obra e Fiador (1:N - múltiplos fiadores por obra)
model VinculoFiador {
  id                 String               @id @default(uuid())
  obraId             String
  fiadorId           String
  percentualGarantia Decimal              @db.Decimal(5, 2) // Ex: 50.00
  valorGarantia      Decimal              @db.Decimal(18, 2)
  observacoes        String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  // Relações
  obra               Obra                 @relation(fields: [obraId], references: [id], onDelete: Cascade)
  fiador             Fiador               @relation(fields: [fiadorId], references: [id])
  bensVinculados     VinculoBemGarantia[] // Múltiplos bens por fiador
}

// Vínculo entre Fiador e seus Bens de Garantia na Obra
model VinculoBemGarantia {
  id              String        @id @default(uuid())
  vinculoFiadorId String
  bemId           String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  // Relações
  vinculoFiador   VinculoFiador @relation(fields: [vinculoFiadorId], references: [id], onDelete: Cascade)
  bem             Bem           @relation(fields: [bemId], references: [id])
}

// --------------------------------------------------------
// OPERAÇÕES FINANCEIRAS — Modelo Dual Tranche
// --------------------------------------------------------

enum TipoOperacao {
  A_PERFORMAR
  PERFORMADA
  SALDO_PERFORMADO
}

enum TipoLancamentoSaldoPerformado {
  CREDITO
  DEBITO
  AJUSTE_CREDITO
  AJUSTE_DEBITO
}

enum StatusWorkflowOperacao {
  EM_EDICAO
  FINALIZADA
  EM_APROVACAO
  APROVADA
  REJEITADA
}

enum StatusFinanceiroOperacao {
  ABERTO
  VENCIDO
  LIQUIDADO
}

enum PapelAprovacaoOperacao {
  FUNDO
  FIADOR
}

enum StatusAprovacaoPapel {
  PENDENTE
  APROVADA
  REJEITADA
}

enum TipoPagamentoOrdem {
  PIX
  TED
  BOLETO
  CARTAO
}

enum TipoDocumentoOrdem {
  NOTA_FISCAL
  PEDIDO_COMPRA
  CONTRATO
  RECIBO
  OUTRO
}


model Operacao {
  id                     String                   @id @default(uuid())
  codigo                 String                   @unique

  construtoraId          String
  obraId                 String
  medicaoId              String?

  tipo                   TipoOperacao

  dataReferencia         DateTime
  dataSolicitacao        DateTime                 @default(now())
  dataFinalizacao        DateTime?
  dataAprovacao          DateTime?
  dataRejeicao           DateTime?
  dataPagamentoPrevista  DateTime?
  dataPagamentoEfetiva   DateTime?

  valorTotalOrdens       Decimal                  @db.Decimal(18, 2)
  taxaJurosMensal        Decimal                  @db.Decimal(10, 4)
  taxaAdministrativa     Decimal                  @db.Decimal(10, 4)
  jurosProjetados        Decimal                  @db.Decimal(18, 2)
  taxasAdministrativas   Decimal                  @db.Decimal(18, 2)
  valorDesagio           Decimal                  @db.Decimal(18, 2)
  valorBruto             Decimal                  @db.Decimal(18, 2)
  percentualDesagio      Decimal                  @db.Decimal(5, 2)

  statusWorkflow         StatusWorkflowOperacao   @default(EM_EDICAO)
  statusFinanceiro       StatusFinanceiroOperacao @default(ABERTO)
  exigeAprovacaoFiador   Boolean                  @default(false)
  aprovacaoFundoStatus   StatusAprovacaoPapel     @default(PENDENTE)
  aprovacaoFiadorStatus  StatusAprovacaoPapel     @default(PENDENTE)
  aprovacaoFundoData     DateTime?
  aprovacaoFiadorData    DateTime?
  aprovacaoFundoMotivo   String?                  @db.Text
  aprovacaoFiadorMotivo  String?                  @db.Text
  aprovacaoFundoPorId    String?
  aprovacaoFiadorPorId   String?

  aprovadorId            String?
  motivoRejeicao         String?                  @db.Text

  operacoesRecompradas   Json?

  // Rastreamento de recompra (para ops À Performar)
  valorRecomprado          Decimal?  @db.Decimal(18, 2)
  statusRecompra           String?   // PENDENTE | PARCIAL | TOTAL

  // Saldo performado consumido ao criar uma À Performar
  saldoPerformadoConsumido Decimal?  @db.Decimal(18, 2)

  // Dados da NF (para ops Performadas)
  nfNumero                 String?
  nfDataEmissao            DateTime?
  nfValorBruto             Decimal?  @db.Decimal(18, 2)
  nfRetencoes              Decimal?  @db.Decimal(18, 2)

  // Referência à PrevisaoMedicao do módulo de engenharia (para ops Performadas)
  previsaoMedicaoId        String?

  // Descrição de referência da NF (para reajuste/complemento, sem medição)
  nfReferencia             String?

  observacoes            String?                  @db.Text
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  construtora            Construtora              @relation(fields: [construtoraId], references: [id])
  obra                   Obra                     @relation(fields: [obraId], references: [id])
  medicao                Medicao?                 @relation(fields: [medicaoId], references: [id])
  previsaoMedicao        PrevisaoMedicao?         @relation("OperacoesPerformadas", fields: [previsaoMedicaoId], references: [id])
  aprovador              Usuario?                 @relation("OperacoesAprovadas", fields: [aprovadorId], references: [id])
  aprovadorFundo         Usuario?                 @relation("OperacoesAprovadasFundo", fields: [aprovacaoFundoPorId], references: [id])
  aprovadorFiador        Usuario?                 @relation("OperacoesAprovadasFiador", fields: [aprovacaoFiadorPorId], references: [id])
  ordens                 OrdemPagamento[]
  recomprasEmitidas      RecompraOperacao[]       @relation("RecomprasEmitidas")
  recomprasRecebidas     RecompraOperacao[]       @relation("RecomprasRecebidas")
  historicoAprovacoes    OperacaoAprovacaoHistorico[]
  lancamentosOrigemSaldo SaldoPerformadoLancamento[] @relation("LancamentoSaldoOrigem")
  lancamentosDestinoSaldo SaldoPerformadoLancamento[] @relation("LancamentoSaldoDestino")

  @@index([construtoraId])
  @@index([obraId])
  @@index([statusWorkflow])
  @@index([statusFinanceiro])
  @@index([tipo])
  @@index([aprovacaoFundoStatus])
  @@index([aprovacaoFiadorStatus])
}

model SaldoPerformadoLancamento {
  id                  String                       @id @default(uuid())
  construtoraId       String
  obraId              String
  tipo                TipoLancamentoSaldoPerformado
  valor               Decimal                      @db.Decimal(18, 2)
  saldoAposLancamento Decimal?                     @db.Decimal(18, 2)
  operacaoOrigemId    String?
  operacaoDestinoId   String?
  observacoes         String?                      @db.Text
  createdAt           DateTime                     @default(now())

  construtora         Construtora                  @relation(fields: [construtoraId], references: [id], onDelete: Cascade)
  obra                Obra                         @relation(fields: [obraId], references: [id], onDelete: Cascade)
  operacaoOrigem      Operacao?                    @relation("LancamentoSaldoOrigem", fields: [operacaoOrigemId], references: [id], onDelete: SetNull)
  operacaoDestino     Operacao?                    @relation("LancamentoSaldoDestino", fields: [operacaoDestinoId], references: [id], onDelete: SetNull)
  alocacoesCredito    SaldoPerformadoAlocacao[]    @relation("AlocacaoCredito")
  alocacoesDebito     SaldoPerformadoAlocacao[]    @relation("AlocacaoDebito")

  @@index([construtoraId, obraId, createdAt])
  @@index([obraId, createdAt])
  @@index([operacaoOrigemId])
  @@index([operacaoDestinoId])
}

model SaldoPerformadoAlocacao {
  id                   String                    @id @default(uuid())
  lancamentoCreditoId  String
  lancamentoDebitoId   String
  valorAlocado         Decimal                   @db.Decimal(18, 2)
  createdAt            DateTime                  @default(now())

  lancamentoCredito    SaldoPerformadoLancamento @relation("AlocacaoCredito", fields: [lancamentoCreditoId], references: [id], onDelete: Cascade)
  lancamentoDebito     SaldoPerformadoLancamento @relation("AlocacaoDebito", fields: [lancamentoDebitoId], references: [id], onDelete: Cascade)

  @@index([lancamentoCreditoId])
  @@index([lancamentoDebitoId])
  @@unique([lancamentoCreditoId, lancamentoDebitoId])
}

model OperacaoAprovacaoHistorico {
  id         String                @id @default(uuid())
  operacaoId String
  usuarioId  String
  papel      PapelAprovacaoOperacao
  decisao    StatusAprovacaoPapel
  motivo     String?               @db.Text
  createdAt  DateTime              @default(now())

  operacao   Operacao              @relation(fields: [operacaoId], references: [id], onDelete: Cascade)
  usuario    Usuario               @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([operacaoId, createdAt])
  @@index([usuarioId])
}

model OrdemPagamento {
  id               String             @id @default(uuid())
  operacaoId       String
  credorId         String?

  tipoDocumento    TipoDocumentoOrdem @default(OUTRO)
  tipoDocumentoNome String?
  numeroDocumento  String
  valorTotal       Decimal            @db.Decimal(18, 2)
  tipoPagamento    TipoPagamentoOrdem
  codigoBarras     String?
  observacoes      String?            @db.Text

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  operacao         Operacao           @relation(fields: [operacaoId], references: [id], onDelete: Cascade)
  credor           Credor?            @relation(fields: [credorId], references: [id])
  apropriacoesOrcamentarias ApropriacaoOrcamentaria[]
  documentos                DocumentoOrdem[]

  @@index([operacaoId])
  @@index([credorId])
}

model RecompraOperacao {
  id                    String   @id @default(uuid())
  operacaoPerformadaId  String
  operacaoAPerformarId  String
  valorRecomprado       Decimal  @db.Decimal(18, 2)
  tipo                  String   // TOTAL | PARCIAL
  createdAt             DateTime @default(now())

  operacaoPerformada   Operacao @relation("RecomprasEmitidas",  fields: [operacaoPerformadaId], references: [id], onDelete: Cascade)
  operacaoAPerformar   Operacao @relation("RecomprasRecebidas", fields: [operacaoAPerformarId],  references: [id])

  @@index([operacaoPerformadaId])
  @@index([operacaoAPerformarId])
}

model ApropriacaoOrcamentaria {
  id                   String          @id @default(uuid())
  ordemPagamentoId     String
  itemVisaoGerencialId String?

  subEtapaCodigo       String
  subEtapaDescricao    String
  etapaNome            String

  percentual           Decimal         @db.Decimal(5, 2)
  valor                Decimal         @db.Decimal(18, 2)
  percentualComprado   Decimal         @default(0) @db.Decimal(5, 2)

  tipoCusto            TipoCustoApropriacao @default(DIRETO)
  subcategoriaDireta   SubcategoriaCustoDireto?
  itemCustoIndiretoId  String?

  ordemPagamento       OrdemPagamento      @relation(fields: [ordemPagamentoId], references: [id], onDelete: Cascade)
  itemVisaoGerencial   ItemVisaoGerencial? @relation(fields: [itemVisaoGerencialId], references: [id])
  itemCustoIndireto    ItemCustoIndireto?  @relation(fields: [itemCustoIndiretoId], references: [id])

  @@index([ordemPagamentoId])
  @@index([itemCustoIndiretoId])
}

model ItemCustoIndireto {
  id            String      @id @default(uuid())
  construtoraId String
  nome          String
  descricao     String?
  ordem         Int         @default(0)
