  fiador        Fiador               @relation(fields: [fiadorId], references: [id], onDelete: Cascade)
  documentos    Documento[]
  vinculosObras VinculoBemGarantia[] // Vínculos com obras
}

model Documento {
  id             String       @id @default(uuid())
