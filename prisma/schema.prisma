  fundoId        String?
  fiadorId       String?
  contratanteId  String?
  bemId          String?
  obraId         String? // Vinculação a uma obra
  aditivoId      String? // Vinculação a um aditivo
  reajusteId     String? // Vinculação a um reajuste
  empenhoId      String? // Vinculação a um empenho
